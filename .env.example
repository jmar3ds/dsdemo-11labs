
# ElevenLabs API key (get one at https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=your_api_key_here

# Optional: override the default TTS model used by generate_voice.py
# Recommended for PT-BR: eleven_multilingual_v2
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional: override the default voice (must match a name in data/voice_catalog.json)
# DEFAULT_VOICE=warm_female_br

# ElevenAgents demo: cloud agent ID, filled in after the agent is created
# on the ElevenLabs dashboard. See docs/ElevenAgents_demo.md for the cloud-agent path.
ELEVENLABS_AGENT_ID=

# Optional: override the mock backend URL (defaults to http://127.0.0.1:8000)
# MOCK_BACKEND_URL=http://127.0.0.1:8000
